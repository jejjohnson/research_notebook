# =============================================================================
# .env.example  —  copy to .env and fill in your values
# =============================================================================
# Run:  make init
# This file is committed to git.  .env is gitignored.
# =============================================================================

# ---------------------------------------------------------------------------
# Package / path overrides
# These match the Makefile defaults; only set them if you want a different value.
# ---------------------------------------------------------------------------
PKGROOT=src/myproject

# ---------------------------------------------------------------------------
# Python tooling
# ---------------------------------------------------------------------------
# Override the uv-managed Python if needed (usually leave blank)
# PYTHON=python3.12

# ---------------------------------------------------------------------------
# CI / publishing configuration (fill in only if you use these)
# ---------------------------------------------------------------------------
# PyPI token (for use by your CI workflows or publishing tools)
# PYPI_TOKEN=

# GitHub personal access token (read:packages scope)
# GITHUB_TOKEN=
